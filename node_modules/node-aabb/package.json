{
  "name": "node-aabb",
  "version": "0.1.0",
  "description": "Axis-aligned bounding box math for JavaScript",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm test",
    "test": "npm run build && node test/aabb.test.js"
  },
  "keywords": [
    "aabb",
    "bounding-box",
    "geometry",
    "minecraft"
  ],
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "require": "./lib/index.js",
      "default": "./lib/index.js"
    }
  },
  "files": [
    "lib",
    "src",
    "README.md",
    "LICENSE"
  ],
  "author": "generel_schwerz",
  "license": "GPL-3.0",
  "peerDependencies": {
    "vec3": ">=0.1.7 <0.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "typescript": "^5.5.2",
    "vec3": "^0.1.7"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nxg-org/node-aabb.git"
  }
}
